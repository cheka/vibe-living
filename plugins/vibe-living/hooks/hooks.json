{
  "description": "Show a local movement companion only while the coding agent is working.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/hook.py\" session",
            "timeout": 30,
            "statusMessage": "Starting Vibe Living"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/hook.py\" working",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/hook.py\" working",
            "timeout": 30
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/hook.py\" waiting",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/hook.py\" working",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/hook.py\" done",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
